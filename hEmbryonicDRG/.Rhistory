download.file(meta_fpath, meta_tmp, mode = "wb")
metadata <- read.table(gzfile(meta_tmp), header = TRUE, sep = "\t", row.names = 1)
View(metadata)
library(tidyverse)
gc()
metadata <- column_to_rownames( metadata, var = cell)
metadata <- column_to_rownames( metadata, var = 'cell')
View(metadata)
metadata <- column_to_rownames( data.frame(metadata), var = 'cell')
str(metadata)
rlang::last_trace()
rlang::last_trace(drop = FALSE)
metadata <- column_to_rownames( remove_rownames(metadata), var = 'cell')
